# Copy to .env.local (gitignored) and fill in, OR export these in your shell / the
# plugin env. Do NOT commit real secrets.

# Backend (/api/v1):
#   local   http://localhost:9310
#   preview https://preview.eu.promethist.ai
#   prod    https://eu.promethist.ai
PROMETHIST_BASE_URL=https://preview.eu.promethist.ai

# Next.js app that serves /api/auth/session. Defaults to PROMETHIST_BASE_URL
# (same host on preview/prod). For local dev set http://localhost:3000.
# PROMETHIST_WEB_URL=https://preview.eu.promethist.ai

