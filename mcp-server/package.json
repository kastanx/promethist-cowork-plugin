{
  "name": "promethist-platform-mcp",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "MCP server that wraps the Promethist Platform REST API (/api/v1), authenticating as the logged-in user.",
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test:e2e": "tsx test/e2e.ts",
    "bench": "npm run build && node benchmark/run.mjs",
    "inspect": "npx @modelcontextprotocol/inspector npx tsx src/index.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
